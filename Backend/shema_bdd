

-- Extension et trigger UUID supprimés car inutiles avec BIGSERIAL


-- users
CREATE TABLE users (
  id BIGSERIAL PRIMARY KEY,
  name VARCHAR(255),
  email VARCHAR(255) NOT NULL UNIQUE,
  password VARCHAR(255) NOT NULL,
  role VARCHAR(50) NOT NULL DEFAULT 'Client',
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
);


-- quotes
CREATE TABLE quotes (
  id BIGSERIAL PRIMARY KEY,
  name VARCHAR(255) NOT NULL,
  email VARCHAR(255) NOT NULL,
  service_type VARCHAR(100) NOT NULL,
  budget_range VARCHAR(50),
  timeline VARCHAR(50),
  description TEXT NOT NULL,
  status VARCHAR(50) NOT NULL DEFAULT 'pending',
  payment_status VARCHAR(50) NOT NULL DEFAULT 'unpaid',
  deposit_amount INTEGER CHECK (deposit_amount >= 0),
  quoted_amount INTEGER CHECK (quoted_amount >= 0),
  total_amount INTEGER CHECK (total_amount >= 0),
  admin_notes TEXT,
  hours_worked INTEGER DEFAULT 0,
  expenses INTEGER DEFAULT 0,
  created_by BIGINT REFERENCES users(id) ON DELETE SET NULL,
  project_id BIGINT UNIQUE,
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
  client BIGINT REFERENCES users(id) ON DELETE SET NULL
);


-- payments
CREATE TABLE payments (
  id BIGSERIAL PRIMARY KEY,
  quote_id BIGINT NOT NULL REFERENCES quotes(id) ON DELETE CASCADE,
  amount BIGINT NOT NULL CHECK (amount >= 0),
  currency VARCHAR(3) NOT NULL DEFAULT 'EUR',
  status VARCHAR(50) NOT NULL DEFAULT 'pending',
  method VARCHAR(50),
  transaction_id VARCHAR(255) UNIQUE,
  stripe_intent_id VARCHAR(255),
  paid_at TIMESTAMPTZ,
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
);


-- projects
CREATE TABLE projects (
  id BIGSERIAL PRIMARY KEY,
  quote_id BIGINT NOT NULL UNIQUE REFERENCES quotes(id) ON DELETE CASCADE,
  name VARCHAR(255) NOT NULL,
  slug VARCHAR(255) UNIQUE,
  description TEXT,
  status VARCHAR(50) NOT NULL DEFAULT 'in_progress',
  started_at TIMESTAMPTZ,
  finished_at TIMESTAMPTZ,
  is_public BOOLEAN DEFAULT false,
  thumbnail_url TEXT,
  live_url TEXT,
  github_url TEXT,
  created_at TIMESTAMPTZ NOT NULL DEFAULT NOW(),
  updated_at TIMESTAMPTZ NOT NULL DEFAULT NOW()
);


-- Contrainte finale
ALTER TABLE quotes ADD CONSTRAINT fk_quotes_project 
  FOREIGN KEY (project_id) REFERENCES projects(id) ON DELETE SET NULL;

